    series{type="1_dp_after/st_close"}@st                             _x100    _    _  -2m    _
    series{type="1_dp_after/st_close"}                                _x100    _    _   60    _
    series{type="1_dp_after/st_closer"}@st                            _x100    _    _  -1m    _
